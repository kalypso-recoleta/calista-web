---
import Layout from '../layouts/Layout.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { whatsappLink } from '../lib/whatsapp';

const waVender = whatsappLink(
  'Hola Calista, quiero vender mi propiedad. ¿Cómo es el proceso?'
);
const waAdmin = whatsappLink(
  'Hola Calista, quiero que administren el alquiler de mi propiedad.'
);

const pasosVender = [
  {
    n: '01',
    t: 'Tasación honesta',
    d: 'Visitamos tu propiedad y te damos un precio realista, basado en la zona y el mercado actual. Sin inflar para captarte ni subvaluar para vender rápido.',
  },
  {
    n: '02',
    t: 'Fotos y publicación',
    d: 'Fotografiamos la propiedad y la publicamos acá, con buena presentación y difusión por nuestros canales y WhatsApp.',
  },
  {
    n: '03',
    t: 'Visitas y negociación',
    d: 'Coordinamos y acompañamos cada visita, filtramos a los interesados serios y negociamos por vos.',
  },
  {
    n: '04',
    t: 'Cierre con respaldo legal',
    d: 'Te derivamos a profesionales legales independientes para la escritura y los trámites. Acompañamos hasta la firma.',
  },
];

const incluyeAdmin = [
  'Búsqueda y selección de inquilinos',
  'Contrato y garantías en regla',
  'Cobro del alquiler y rendición mensual',
  'Coordinación de mantenimiento y reparaciones',
  'Un solo interlocutor: nosotros nos ocupamos',
];
---

<Layout
  title="Propietarios"
  description="¿Querés vender o alquilar tu propiedad? Tasamos, publicamos y administramos con criterio y honestidad."
>
  <!-- HERO -->
  <section class="section hero">
    <div class="container narrow">
      <p class="eyebrow">Para propietarios</p>
      <h1>Tenés una propiedad. Nosotros nos ocupamos del resto.</h1>
      <p class="lead">
        Sea para venderla, alquilarla o administrarla, te acompañamos con la
        misma honestidad de siempre: precios realistas, información clara y tu
        decisión en el centro.
      </p>
      <div class="hero-cta">
        <a href="#vender" class="btn btn--primary">Quiero vender</a>
        <a href="#administracion" class="btn btn--ghost">Quiero alquilar / administrar</a>
      </div>
    </div>
  </section>

  <!-- VENDER -->
  <section id="vender" class="section bloque">
    <div class="container">
      <header class="cab">
        <p class="eyebrow">Vender</p>
        <h2>Vendé tu propiedad con acompañamiento real.</h2>
        <p class="lead">
          No trabajamos con apuro ni con letra chica. Te explicamos cada paso y
          cuidamos tu propiedad como si fuera nuestra.
        </p>
      </header>

      <ol class="pasos">
        {
          pasosVender.map((p) => (
            <li>
              <span class="num">{p.n}</span>
              <h3>{p.t}</h3>
              <p>{p.d}</p>
            </li>
          ))
        }
      </ol>

      <div class="cta-linea">
        <WhatsAppButton href={waVender} label="Quiero vender mi propiedad" />
        <a href="/contacto" class="btn btn--ghost">Enviar los datos por formulario</a>
      </div>
    </div>
  </section>

  <!-- ADMINISTRACIÓN -->
  <section id="administracion" class="section bloque alt">
    <div class="container admin-grid">
      <div>
        <p class="eyebrow">Administración de alquileres</p>
        <h2>¿Alquilás tu propiedad? Olvidate de estar encima.</h2>
        <p class="lead">
          Nos ocupamos de todo el ciclo del alquiler para que vos solo recibas
          tu renta, tranquilo. Ideal si vivís lejos o no querés lidiar con el
          día a día.
        </p>
        <div class="cta-linea">
          <WhatsAppButton href={waAdmin} label="Quiero administrar mi alquiler" />
        </div>
      </div>

      <ul class="incluye">
        {incluyeAdmin.map((i) => <li>{i}</li>)}
      </ul>
    </div>
  </section>

  <!-- CIERRE -->
  <section class="section">
    <div class="container">
      <div class="cierre">
        <h2>¿Hablamos de tu propiedad?</h2>
        <p>Contanos qué tenés y qué querés hacer. Te respondemos personalmente.</p>
        <div class="cta-linea center">
          <WhatsAppButton href={waVender} label="Escribir por WhatsApp" />
          <a href="/contacto" class="btn btn--ghost">Ir al formulario</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .narrow {
    max-width: 760px;
  }
  .hero {
    padding-bottom: 1rem;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.8rem;
  }
  .cab {
    max-width: 62ch;
    margin-bottom: 2rem;
  }

  .bloque.alt {
    background: var(--surface);
    border-block: 1px solid var(--line);
  }

  /* Pasos vender */
  .pasos {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1.5rem;
  }
  .pasos li {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow);
  }
  .pasos .num {
    font-family: var(--display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--violet);
    letter-spacing: 0.05em;
  }
  .pasos h3 {
    margin: 0.5rem 0 0.4rem;
  }
  .pasos p {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
  }

  /* Administración */
  .admin-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .incluye {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.8rem;
  }
  .incluye li {
    position: relative;
    padding-left: 2rem;
    font-size: 1.02rem;
  }
  .incluye li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.45em;
    width: 13px;
    height: 7px;
    border-left: 2.5px solid var(--violet);
    border-bottom: 2.5px solid var(--violet);
    transform: rotate(-45deg);
  }

  .cta-linea {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.8rem;
  }
  .cta-linea.center {
    justify-content: center;
  }

  .cierre {
    background: var(--brand);
    color: #fff;
    border-radius: 22px;
    padding: clamp(2rem, 5vw, 3.5rem);
    text-align: center;
  }
  .cierre h2 {
    color: #fff;
    margin-bottom: 0.4rem;
  }
  .cierre p {
    color: #cfc8ee;
    margin: 0;
  }

  @media (max-width: 820px) {
    .admin-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
