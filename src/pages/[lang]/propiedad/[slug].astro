---
import { slugify } from '../../../lib/slug';
import { getCollection } from 'astro:content';
import PropiedadBody from '../../../components/pages/PropiedadBody.astro';

export async function getStaticPaths() {
  const biens = await getCollection('biens');
  const langs = ['fr', 'en'];
  return biens.flatMap((bien) =>
    langs.map((lang) => ({ params: { lang, slug: slugify(bien.id) }, props: { bien } }))
  );
}
const { bien } = Astro.props;
---
<PropiedadBody bien={bien} />
