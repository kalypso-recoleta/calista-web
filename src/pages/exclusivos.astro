---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ExclusivaFeature from '../components/ExclusivaFeature.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { whatsappLink } from '../lib/whatsapp';

const biens = (await getCollection('biens'))
  .filter((b) => b.data.exclusivo)
  .sort((a, b) => +b.data.fecha - +a.data.fecha);

const wa = whatsappLink(
  'Hola Calista, me interesa la cartera exclusiva. Quisiera una consulta privada.'
);
---

<Layout
  title="Exclusivos"
  description="Cartera exclusiva de propiedades premium, con una comercialización discreta y personalizada."
>
  <!-- HERO SOMBRE -->
  <section class="hero-ex">
    <div class="container">
      <p class="eyebrow on-dark">Cartera exclusiva</p>
      <h1>Propiedades exclusivas</h1>
      <p class="lead-ex">
        Una selección reducida de propiedades de excepción. Las comercializamos
        con discreción y de forma personalizada, coordinando visitas únicamente
        con clientes calificados.
      </p>
    </div>
    <div class="hero-glow" aria-hidden="true"></div>
  </section>

  <!-- SHOWCASE -->
  <section class="section showcase">
    <div class="container">
      {
        biens.length > 0 ? (
          <div class="features">
            {biens.map((bien, i) => (
              <ExclusivaFeature bien={bien} indice={i} />
            ))}
          </div>
        ) : (
          <p class="lead vacio-ex">
            Por el momento no hay propiedades publicadas en la cartera exclusiva.
            Si buscás algo en particular, escribinos para una búsqueda privada.
          </p>
        )
      }
    </div>
  </section>

  <!-- APPEL FINAL -->
  <section class="section">
    <div class="container">
      <div class="cierre-ex">
        <p class="eyebrow on-dark">Búsqueda privada</p>
        <h2>¿Buscás algo a la altura?</h2>
        <p>
          Algunas propiedades no las publicamos abiertamente, por pedido de sus
          dueños. Contanos qué buscás y lo gestionamos con total discreción.
        </p>
        <WhatsAppButton href={wa} label="Hacer una consulta privada" />
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero sombre — pose le ton premium, différent des autres pages */
  .hero-ex {
    position: relative;
    overflow: hidden;
    background: var(--brand);
    color: #fff;
    padding-block: clamp(3.5rem, 8vw, 6rem);
  }
  .hero-ex .container {
    position: relative;
    z-index: 1;
    max-width: 820px;
  }
  .hero-ex h1 {
    color: #fff;
    font-size: clamp(2.6rem, 6vw, 4.2rem);
    margin-bottom: 1rem;
  }
  .on-dark {
    color: #c9a0e8;
  }
  .lead-ex {
    color: #cfc6dd;
    font-size: 1.2rem;
    max-width: 56ch;
    margin: 0;
  }
  /* Halo violet discret */
  .hero-glow {
    position: absolute;
    top: -30%;
    right: -10%;
    width: 60%;
    height: 160%;
    background: radial-gradient(
      closest-side,
      rgba(144, 32, 198, 0.45),
      transparent
    );
    filter: blur(20px);
    z-index: 0;
  }

  .showcase {
    padding-top: clamp(1.5rem, 4vw, 2.5rem);
  }
  .vacio-ex {
    text-align: center;
    padding-block: 2rem;
  }

  /* Appel final sur fond sombre */
  .cierre-ex {
    background: var(--brand);
    color: #fff;
    border-radius: 22px;
    padding: clamp(2rem, 5vw, 3.5rem);
    text-align: center;
  }
  .cierre-ex h2 {
    color: #fff;
    margin-bottom: 0.6rem;
  }
  .cierre-ex p {
    color: #cfc6dd;
    max-width: 52ch;
    margin: 0 auto 1.6rem;
  }
  .cierre-ex :global(.btn) {
    margin-inline: auto;
  }
</style>
