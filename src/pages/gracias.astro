---
import Layout from '../layouts/Layout.astro';
import { whatsappLink } from '../lib/whatsapp';
---

<Layout title="Gracias" description="Recibimos tu consulta.">
  <section class="section">
    <div class="container center">
      <p class="eyebrow">Recibido</p>
      <h1>¡Gracias por escribirnos!</h1>
      <p class="lead">
        Recibimos tu consulta y te vamos a responder a la brevedad. Si es algo
        urgente, escribinos directamente por WhatsApp.
      </p>
      <div class="cta">
        <a href="/" class="btn btn--ghost">Volver al inicio</a>
        <a href={whatsappLink('Hola Calista, acabo de enviar una consulta.')} class="btn btn--wa" target="_blank" rel="noopener">
          Abrir WhatsApp
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .center {
    max-width: 620px;
    text-align: center;
  }
  .cta {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
    margin-top: 2rem;
    flex-wrap: wrap;
  }
</style>
