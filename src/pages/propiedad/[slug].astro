---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PropertyGallery from '../../components/PropertyGallery.astro';
import PropertyMap from '../../components/PropertyMap.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import { img } from '../../lib/cloudinary';
import { whatsappBien } from '../../lib/whatsapp';
import {
  formatPrecio,
  formatUbicacion,
  formatSuperficie,
  tipoLabel,
  operacionLabel,
  estadoLabel,
} from '../../lib/format';

export async function getStaticPaths() {
  const biens = await getCollection('biens');
  return biens.map((bien) => ({ params: { slug: bien.id }, props: { bien } }));
}

const { bien } = Astro.props;
const d = bien.data;
const { Content } = await render(bien);

const url = new URL(`/propiedad/${bien.id}`, Astro.site).toString();
const wa = whatsappBien({ titulo: d.titulo, ref: bien.id, url });
const superficie = formatSuperficie(d);
const ogImage = d.imagenes[0]
  ? img(d.imagenes[0], { w: 1200, h: 630 })
  : undefined;

const specs = [
  d.dormitorios != null && { label: 'Dormitorios', value: d.dormitorios },
  d.banos != null && { label: 'Baños', value: d.banos },
  d.cocheras != null && { label: 'Cocheras', value: d.cocheras },
  superficie && { label: 'Superficie', value: superficie },
  d.entrega && { label: 'Entrega', value: d.entrega },
  d.financiacion && { label: 'Financiación', value: 'Disponible' },
].filter(Boolean) as { label: string; value: string | number }[];
---

<Layout title={d.titulo} description={d.descripcion} image={ogImage}>
  <article class="section detalle">
    <div class="container">
      <nav class="crumbs" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <span>/</span>
        <a href={d.operacion === 'venta' ? '/comprar' : '/alquilar'}>
          {operacionLabel(d.operacion)}
        </a>
        <span>/</span>
        <span>{d.titulo}</span>
      </nav>

      <PropertyGallery imagenes={d.imagenes} titulo={d.titulo} />

      <div class="layout">
        <div class="main">
          <p class="loc">{tipoLabel(d.tipo)} · {formatUbicacion(d)}</p>
          <h1>{d.titulo}</h1>

          <div class="meta-row">
            <span class="badge">{operacionLabel(d.operacion)}</span>
            {d.desarrollo && <span class="badge">En pozo</span>}
            {d.exclusivo && <span class="badge badge--exclusivo">Exclusivo</span>}
            {
              d.estado !== 'disponible' && (
                <span class={`badge badge--${d.estado}`}>{estadoLabel(d.estado)}</span>
              )
            }
          </div>

          {
            specs.length > 0 && (
              <ul class="specs">
                {specs.map((s) => (
                  <li>
                    <span class="v">{s.value}</span>
                    <span class="k">{s.label}</span>
                  </li>
                ))}
              </ul>
            )
          }

          <div class="prose">
            <Content />
          </div>

          <div class="mapa">
            <h3>Ubicación</h3>
            <PropertyMap ubicacion={d.ubicacion} zona={formatUbicacion(d)} />
          </div>
        </div>

        <aside class="side">
          <div class="cta-card">
            <p class="precio">{formatPrecio(d)}</p>
            <p class="ref">Ref. {bien.id}</p>
            <WhatsAppButton href={wa} full />
            <a href="/contacto" class="btn btn--ghost full-ghost">
              Enviar consulta
            </a>
            <p class="nota">
              Te respondemos personalmente. Sin intermediarios automáticos.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </article>
</Layout>

<style>
  .crumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 1.2rem;
  }
  .crumbs a {
    color: var(--muted);
  }
  .crumbs a:hover {
    color: var(--brand);
  }

  .layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 2.5rem;
    margin-top: 2rem;
    align-items: start;
  }
  .loc {
    color: var(--muted);
    margin: 0 0 0.3rem;
    font-size: 0.9rem;
  }
  .main h1 {
    margin-bottom: 0.8rem;
  }
  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .specs {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 1px;
    padding: 0;
    margin: 0 0 2rem;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .specs li {
    background: var(--surface);
    padding: 1rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .specs .v {
    font-family: var(--display);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--brand);
  }
  .specs .k {
    font-size: 0.78rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .prose {
    font-size: 1.06rem;
    line-height: 1.7;
    max-width: 64ch;
  }
  .prose :global(h2),
  .prose :global(h3) {
    margin-top: 1.6rem;
  }
  .prose :global(strong) {
    color: var(--brand);
  }

  .mapa {
    margin-top: 2.5rem;
  }
  .mapa h3 {
    margin-bottom: 0.8rem;
  }

  .side {
    position: sticky;
    top: 92px;
  }
  .cta-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .cta-card .precio {
    font-family: var(--display);
    font-size: 2rem;
    font-weight: 600;
    color: var(--brand);
    margin: 0;
  }
  .cta-card .ref {
    font-size: 0.8rem;
    color: var(--muted);
    margin: -0.4rem 0 0.4rem;
  }
  .full-ghost {
    width: 100%;
    justify-content: center;
  }
  .cta-card .nota {
    font-size: 0.8rem;
    color: var(--muted);
    margin: 0.3rem 0 0;
    line-height: 1.4;
  }

  @media (max-width: 900px) {
    .layout {
      grid-template-columns: 1fr;
    }
    .side {
      position: static;
      order: -1;
    }
  }
</style>
