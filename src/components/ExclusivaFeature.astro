---
import { slugify } from '../lib/slug';
import type { CollectionEntry } from 'astro:content';
import { img } from '../lib/cloudinary';
import { whatsappBien } from '../lib/whatsapp';
import {
  formatPrecio,
  formatUbicacion,
  formatSuperficie,
  tipoLabel,
} from '../lib/format';
import WhatsAppButton from './WhatsAppButton.astro';
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/utils';

interface Props {
  bien: CollectionEntry<'biens'>;
  indice: number; // pour le numéro éditorial + l'alternance
}
const { bien, indice } = Astro.props;
const d = bien.data;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const href = localizePath(`/propiedad/${slugify(bien.id)}`, lang);

const reverse = indice % 2 === 1;
const num = String(indice + 1).padStart(2, '0');

const url = new URL(`/propiedad/${slugify(bien.id)}`, Astro.site).toString();
const wa = whatsappBien({ titulo: d.titulo, ref: slugify(bien.id), url });
const superficie = formatSuperficie(d, lang);

const specs = [
  d.dormitorios != null && `${d.dormitorios} ${t('spec.dorm')}`,
  d.banos != null && `${d.banos} ${t('spec.banos')}`,
  d.cocheras != null && `${d.cocheras} ${t('spec.coch')}`,
  superficie,
].filter(Boolean) as string[];
---

<article class:list={['feature', { reverse }]}>
  <a class="media" href={href} aria-label={d.titulo}>
    <img
      src={img(d.portada_foto || d.imagenes[0], { w: 1000, h: 760 })}
      alt={d.titulo}
      width="1000"
      height="760"
      loading="lazy"
    />
  </a>

  <div class="content">
    <span class="num" aria-hidden="true">{num}</span>
    <p class="loc">{tipoLabel(d.tipo, lang)} · {formatUbicacion(d)}</p>
    <h2>{d.titulo}</h2>
    <p class="desc">{d.descripcion}</p>

    {
      specs.length > 0 && (
        <ul class="specs">
          {specs.map((s) => (
            <li>{s}</li>
          ))}
        </ul>
      )
    }

    <p class="precio">{formatPrecio(d, lang)}</p>

    <div class="cta">
      <a href={href} class="btn btn--primary">{t('common.ver_propiedad')}</a>
      <WhatsAppButton href={wa} label={t('excl.feature_wa')} />
    </div>
  </div>
</article>

<style>
  .feature {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: center;
    padding-block: clamp(2rem, 5vw, 3.5rem);
    border-bottom: 1px solid var(--line);
  }
  .feature:last-child {
    border-bottom: 0;
  }
  .feature.reverse .media {
    order: 2;
  }

  .media {
    display: block;
    border-radius: 18px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--violet-soft);
    box-shadow: var(--shadow-lg);
  }
  .media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .media:hover img {
    transform: scale(1.03);
  }

  .content {
    position: relative;
  }
  .num {
    font-family: var(--display);
    font-size: clamp(2.5rem, 6vw, 3.6rem);
    font-weight: 500;
    line-height: 1;
    color: var(--violet);
    opacity: 0.22;
    display: block;
    margin-bottom: 0.4rem;
  }
  .loc {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    color: var(--muted);
    margin: 0 0 0.4rem;
  }
  .content h2 {
    font-size: clamp(1.7rem, 3.5vw, 2.4rem);
    margin: 0 0 0.7rem;
  }
  .desc {
    color: var(--muted);
    font-size: 1.05rem;
    max-width: 46ch;
  }
  .specs {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.4rem;
    padding: 0;
    margin: 1.1rem 0;
    font-size: 0.92rem;
    color: var(--ink);
  }
  .specs li {
    position: relative;
  }
  .specs li + li::before {
    content: '';
    position: absolute;
    left: -0.75rem;
    top: 50%;
    width: 3px;
    height: 3px;
    background: var(--violet);
    border-radius: 50%;
    transform: translateY(-50%);
  }
  .precio {
    font-family: var(--display);
    font-size: 1.9rem;
    font-weight: 600;
    color: var(--brand);
    margin: 0 0 1.3rem;
  }
  .cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  @media (max-width: 820px) {
    .feature {
      grid-template-columns: 1fr;
      gap: 1.4rem;
    }
    .feature.reverse .media {
      order: 0;
    }
  }
</style>
