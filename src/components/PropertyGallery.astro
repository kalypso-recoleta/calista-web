---
import { img } from '../lib/cloudinary';

interface Props {
  imagenes: string[];
  titulo: string;
}
const { imagenes, titulo } = Astro.props;
const fotos = imagenes.length ? imagenes : ['/placeholder.svg'];
const varias = fotos.length > 1;
---

<div class="gallery" data-gallery>
  <div class="main">
    <img
      data-main
      src={img(fotos[0], { w: 1200, h: 760 })}
      alt={titulo}
      width="1200"
      height="760"
    />

    {
      varias && (
        <>
          <button type="button" class="nav prev" data-prev aria-label="Foto anterior">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="15 18 9 12 15 6" />
            </svg>
          </button>
          <button type="button" class="nav next" data-next aria-label="Foto siguiente">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="9 18 15 12 9 6" />
            </svg>
          </button>
        </>
      )
    }

    <span class="count" data-count>1 / {fotos.length}</span>
  </div>

  {
    varias && (
      <div class="thumbs" role="list">
        {fotos.map((f, i) => (
          <button
            type="button"
            class:list={['thumb', { active: i === 0 }]}
            data-full={img(f, { w: 1200, h: 760 })}
            data-index={i}
            aria-label={`Imagen ${i + 1}`}
          >
            <img src={img(f, { w: 180, h: 130 })} alt="" width="180" height="130" loading="lazy" />
          </button>
        ))}
      </div>
    )
  }
</div>

<style>
  .gallery {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .main {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--violet-soft);
    aspect-ratio: 16 / 10;
  }
  .main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Flèches de navigation */
  .nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    border: 0;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    color: var(--brand);
    cursor: pointer;
    box-shadow: 0 2px 10px -3px rgba(0, 0, 0, 0.35);
    transition: background 0.15s, transform 0.15s;
  }
  .nav:hover {
    background: #fff;
    transform: translateY(-50%) scale(1.06);
  }
  .nav:active {
    transform: translateY(-50%) scale(0.96);
  }
  .prev {
    left: 0.8rem;
  }
  .next {
    right: 0.8rem;
  }

  .count {
    position: absolute;
    bottom: 0.8rem;
    right: 0.8rem;
    background: rgba(31, 27, 58, 0.72);
    color: #fff;
    font-size: 0.8rem;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
  }
  .thumbs {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(88px, 1fr);
    gap: 0.5rem;
    overflow-x: auto;
    padding-bottom: 0.2rem;
  }
  .thumb {
    border: 2px solid transparent;
    border-radius: 10px;
    overflow: hidden;
    padding: 0;
    cursor: pointer;
    background: none;
    aspect-ratio: 16 / 11;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .thumb.active {
    border-color: var(--violet);
  }

  @media (max-width: 640px) {
    .nav {
      width: 38px;
      height: 38px;
    }
  }
</style>

<script>
  document.querySelectorAll('[data-gallery]').forEach((g) => {
    const main = g.querySelector<HTMLImageElement>('[data-main]');
    const count = g.querySelector<HTMLElement>('[data-count]');
    const thumbs = Array.from(g.querySelectorAll<HTMLButtonElement>('.thumb'));
    const fotos = thumbs.map((t) => t.getAttribute('data-full') || '');
    let indice = 0;

    function mostrar(i: number) {
      if (!fotos.length || !main) return;
      indice = (i + fotos.length) % fotos.length; // boucle infinie ‹ ›
      main.src = fotos[indice];
      thumbs.forEach((t, k) => t.classList.toggle('active', k === indice));
      if (count) count.textContent = `${indice + 1} / ${fotos.length}`;
      // Garder la miniature active visible
      thumbs[indice]?.scrollIntoView({ block: 'nearest', inline: 'nearest', behavior: 'smooth' });
    }

    thumbs.forEach((t) => {
      t.addEventListener('click', () => mostrar(Number(t.dataset.index)));
    });

    g.querySelector('[data-prev]')?.addEventListener('click', () => mostrar(indice - 1));
    g.querySelector('[data-next]')?.addEventListener('click', () => mostrar(indice + 1));

    // Flèches du clavier
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') mostrar(indice - 1);
      if (e.key === 'ArrowRight') mostrar(indice + 1);
    });

    // Glissement du doigt (mobile)
    let x0: number | null = null;
    const zona = g.querySelector<HTMLElement>('.main');
    zona?.addEventListener('touchstart', (e) => (x0 = e.touches[0].clientX), { passive: true });
    zona?.addEventListener(
      'touchend',
      (e) => {
        if (x0 === null) return;
        const dx = e.changedTouches[0].clientX - x0;
        if (Math.abs(dx) > 40) mostrar(indice + (dx < 0 ? 1 : -1));
        x0 = null;
      },
      { passive: true }
    );
  });
</script>
