---
import { img } from '../lib/cloudinary';

interface Props {
  imagenes: string[];
  titulo: string;
}
const { imagenes, titulo } = Astro.props;
const fotos = imagenes.length ? imagenes : ['/placeholder.svg'];
---

<div class="gallery" data-gallery>
  <div class="main">
    <img
      id="gallery-main"
      src={img(fotos[0], { w: 1200, h: 760 })}
      alt={titulo}
      width="1200"
      height="760"
    />
    <span class="count" data-count>1 / {fotos.length}</span>
  </div>

  {
    fotos.length > 1 && (
      <div class="thumbs" role="list">
        {fotos.map((f, i) => (
          <button
            type="button"
            class:list={['thumb', { active: i === 0 }]}
            data-full={img(f, { w: 1200, h: 760 })}
            data-index={i}
            aria-label={`Imagen ${i + 1}`}
          >
            <img src={img(f, { w: 180, h: 130 })} alt="" width="180" height="130" loading="lazy" />
          </button>
        ))}
      </div>
    )
  }
</div>

<style>
  .gallery {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .main {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--violet-soft);
    aspect-ratio: 16 / 10;
  }
  .main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .count {
    position: absolute;
    bottom: 0.8rem;
    right: 0.8rem;
    background: rgba(31, 27, 58, 0.72);
    color: #fff;
    font-size: 0.8rem;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
  }
  .thumbs {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(88px, 1fr);
    gap: 0.5rem;
    overflow-x: auto;
    padding-bottom: 0.2rem;
  }
  .thumb {
    border: 2px solid transparent;
    border-radius: 10px;
    overflow: hidden;
    padding: 0;
    cursor: pointer;
    background: none;
    aspect-ratio: 16 / 11;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .thumb.active {
    border-color: var(--violet);
  }
</style>

<script>
  document.querySelectorAll('[data-gallery]').forEach((g) => {
    const main = g.querySelector<HTMLImageElement>('#gallery-main');
    const count = g.querySelector<HTMLElement>('[data-count]');
    const thumbs = Array.from(g.querySelectorAll<HTMLButtonElement>('.thumb'));
    thumbs.forEach((t) => {
      t.addEventListener('click', () => {
        const full = t.getAttribute('data-full');
        if (full && main) main.src = full;
        thumbs.forEach((x) => x.classList.remove('active'));
        t.classList.add('active');
        if (count) count.textContent = `${Number(t.dataset.index) + 1} / ${thumbs.length}`;
      });
    });
  });
</script>
