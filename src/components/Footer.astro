---
import { site } from '../lib/site';
import { whatsappLink } from '../lib/whatsapp';
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const L = (p: string) => localizePath(p, lang);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container grid">
    <div class="col">
      <img src="/logo-calista-oscuro.png" alt={site.nombre} class="logo" width="180" height="76" />
      <p class="lema">{site.lema}</p>
    </div>

    <div class="col">
      <h4>{t('footer.propiedades')}</h4>
      <a href={L('/comprar')}>{t('nav.comprar')}</a>
      <a href={L('/alquilar')}>{t('nav.alquilar')}</a>
      <a href={L('/desarrollos')}>{t('footer.desarrollos')}</a>
      <a href={L('/terrenos')}>{t('nav.terrenos')}</a>
      <a href={L('/exclusivos')}>{t('nav.exclusivos')}</a>
    </div>

    <div class="col">
      <h4>{t('footer.propietarios')}</h4>
      <a href={L('/propietarios') + '#vender'}>{t('footer.vender')}</a>
      <a href={L('/propietarios') + '#administracion'}>{t('footer.administracion')}</a>
    </div>

    <div class="col">
      <h4>{t('footer.agencia')}</h4>
      <a href={L('/resenas')}>{t('nav.resenas')}</a>
      <a href={L('/historia')}>{t('footer.nuestra_historia')}</a>
      <a href={L('/contacto')}>{t('footer.contacto')}</a>
      <a href={whatsappLink()} target="_blank" rel="noopener">WhatsApp</a>
    </div>

    <div class="col">
      <h4>{t('footer.contacto_titulo')}</h4>
      <a href={`mailto:${site.email}`}>{site.email}</a>
      <span>{site.telefono}</span>
      <span>{site.direccion}</span>
    </div>
  </div>

  <div class="container legal">
    <span>© {year} {site.nombre}</span>
    <span>Asunción · Paraguay</span>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    background: var(--brand);
    color: #d9d4ee;
    padding-block: 3.5rem 1.5rem;
  }
  .grid {
    display: grid;
    grid-template-columns: 1.4fr repeat(4, 1fr);
    gap: 1.6rem;
  }
  .col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .col h4 {
    font-family: var(--body);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #b3aada;
    margin: 0 0 0.4rem;
  }
  .col a,
  .col span {
    color: #d9d4ee;
    font-size: 0.95rem;
  }
  .col a:hover {
    color: #fff;
  }
  .logo {
    height: 42px;
    width: auto;
    align-self: flex-start;
    margin-bottom: 0.9rem;
  }
  .lema {
    color: #b3aada;
    max-width: 34ch;
    font-size: 0.95rem;
  }
  .legal {
    display: flex;
    justify-content: space-between;
    margin-top: 2.5rem;
    padding-top: 1.3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    font-size: 0.85rem;
    color: #9990c4;
  }
  @media (max-width: 760px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 460px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .legal {
      flex-direction: column;
      gap: 0.3rem;
    }
  }
</style>
