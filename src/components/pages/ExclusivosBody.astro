---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ExclusivaFeature from '../ExclusivaFeature.astro';
import WhatsAppButton from '../WhatsAppButton.astro';
import { whatsappLink } from '../../lib/whatsapp';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const biens = (await getCollection('biens'))
  .filter((b) => b.data.exclusivo)
  .sort((a, b) => +b.data.fecha - +a.data.fecha);

const wa = whatsappLink(
  'Hola Calista, me interesa la cartera exclusiva. Quisiera una consulta privada.'
);
---

<Layout title={t('excl.hero_title')} description={t('excl.hero_lead')}>
  <section class="hero-ex">
    <div class="container">
      <p class="eyebrow on-dark">{t('excl.hero_eyebrow')}</p>
      <h1>{t('excl.hero_title')}</h1>
      <p class="lead-ex">{t('excl.hero_lead')}</p>
    </div>
    <div class="hero-glow" aria-hidden="true"></div>
  </section>

  <section class="section showcase">
    <div class="container">
      {
        biens.length > 0 ? (
          <div class="features">
            {biens.map((bien, i) => (
              <ExclusivaFeature bien={bien} indice={i} />
            ))}
          </div>
        ) : (
          <p class="lead vacio-ex">{t('excl.vacia')}</p>
        )
      }
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cierre-ex">
        <p class="eyebrow on-dark">{t('excl.cierre_eyebrow')}</p>
        <h2>{t('excl.cierre_title')}</h2>
        <p>{t('excl.cierre_text')}</p>
        <WhatsAppButton href={wa} label={t('excl.cierre_wa')} />
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero-ex {
    position: relative;
    overflow: hidden;
    background: var(--brand);
    color: #fff;
    padding-block: clamp(3.5rem, 8vw, 6rem);
  }
  .hero-ex .container {
    position: relative;
    z-index: 1;
    max-width: 820px;
  }
  .hero-ex h1 {
    color: #fff;
    font-size: clamp(2.6rem, 6vw, 4.2rem);
    margin-bottom: 1rem;
  }
  .on-dark {
    color: #c9a0e8;
  }
  .lead-ex {
    color: #cfc6dd;
    font-size: 1.2rem;
    max-width: 56ch;
    margin: 0;
  }
  .hero-glow {
    position: absolute;
    top: -30%;
    right: -10%;
    width: 60%;
    height: 160%;
    background: radial-gradient(closest-side, rgba(144, 32, 198, 0.45), transparent);
    filter: blur(20px);
    z-index: 0;
  }
  .showcase {
    padding-top: clamp(1.5rem, 4vw, 2.5rem);
  }
  .vacio-ex {
    text-align: center;
    padding-block: 2rem;
  }
  .cierre-ex {
    background: var(--brand);
    color: #fff;
    border-radius: 22px;
    padding: clamp(2rem, 5vw, 3.5rem);
    text-align: center;
  }
  .cierre-ex h2 {
    color: #fff;
    margin-bottom: 0.6rem;
  }
  .cierre-ex p {
    color: #cfc6dd;
    max-width: 52ch;
    margin: 0 auto 1.6rem;
  }
  .cierre-ex :global(.btn) {
    margin-inline: auto;
  }
</style>
