---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PropertyCard from '../PropertyCard.astro';
import WhatsAppButton from '../WhatsAppButton.astro';
import Testimonios from '../Testimonios.astro';
import { img } from '../../lib/cloudinary';
import { whatsappLink } from '../../lib/whatsapp';
import { formatPrecio, formatUbicacion } from '../../lib/format';
import { getLangFromUrl, useTranslations, localizePath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const L = (p: string) => localizePath(p, lang);

const todos = await getCollection('biens');
const activos = todos.filter(
  (b) => b.data.estado === 'disponible' || b.data.estado === 'reservado'
);
const destacados = activos.filter((b) => b.data.destacado).slice(0, 6);
const hero = destacados[0] ?? activos[0];

const resenas = (await getCollection('resenas'))
  .filter((r) => r.data.destacada)
  .sort((a, b) => +b.data.fecha - +a.data.fecha)
  .slice(0, 3);

const categorias = [
  { href: '/comprar', label: t('home.cat_comprar'), desc: t('home.cat_comprar_d') },
  { href: '/alquilar', label: t('home.cat_alquilar'), desc: t('home.cat_alquilar_d') },
  { href: '/desarrollos', label: t('home.cat_desarrollos'), desc: t('home.cat_desarrollos_d') },
  { href: '/terrenos', label: t('home.cat_terrenos'), desc: t('home.cat_terrenos_d') },
];

// Messages WhatsApp : volontairement en espagnol (l'agence les lit en espagnol).
const wa = whatsappLink('Hola Calista, quisiera hacer una consulta.');
const waProp = whatsappLink('Hola Calista, quiero vender / alquilar mi propiedad.');
---

<Layout title={t('seo.home_title')} description={t('seo.home_desc')}>
  <!-- HERO -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <p class="eyebrow">{t('home.hero_eyebrow')}</p>
        <h1>{t('home.hero_title')}</h1>
        <p class="lead">{t('home.hero_lead')}</p>
        <div class="hero-cta">
          <a href={L('/comprar')} class="btn btn--primary">{t('home.ver_propiedades')}</a>
          <WhatsAppButton href={wa} label={t('home.hablar_wa')} />
        </div>
      </div>

      {
        hero && (
          <a class="hero-media" href={L(`/propiedad/${hero.id}`)} aria-label={hero.data.titulo}>
            <img
              src={img(hero.data.imagenes[0], { w: 760, h: 620 })}
              alt={hero.data.titulo}
              width="760"
              height="620"
            />
            <div class="hero-tag">
              <span class="ht-precio">{formatPrecio(hero.data, lang)}</span>
              <span class="ht-loc">{formatUbicacion(hero.data)}</span>
            </div>
          </a>
        )
      }
    </div>
  </section>

  <!-- CATEGORÍAS -->
  <section class="section cats-section">
    <div class="container">
      <div class="cats">
        {
          categorias.map((c) => (
            <a href={L(c.href)} class="cat">
              <span class="cat-label">{c.label}</span>
              <span class="cat-desc">{c.desc}</span>
              <span class="cat-arrow" aria-hidden="true">→</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- DESTACADOS -->
  {
    destacados.length > 0 && (
      <section class="section">
        <div class="container">
          <header class="row-head">
            <div>
              <p class="eyebrow">{t('home.destacados_eyebrow')}</p>
              <h2>{t('home.destacados_title')}</h2>
            </div>
            <a href={L('/comprar')} class="ver-todo">{t('common.ver_todas')}</a>
          </header>
          <div class="grid-biens">
            {destacados.map((bien) => (
              <PropertyCard bien={bien} />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- POR QUÉ CALISTA -->
  <section class="section porque">
    <div class="container porque-grid">
      <div class="porque-intro">
        <p class="eyebrow">{t('home.porque_eyebrow')}</p>
        <h2>{t('home.porque_title')}</h2>
        <p class="lead">{t('home.porque_lead')}</p>
      </div>
      <ul class="valores">
        <li>
          <h3>{t('home.valor1_t')}</h3>
          <p>{t('home.valor1_d')}</p>
        </li>
        <li>
          <h3>{t('home.valor2_t')}</h3>
          <p>{t('home.valor2_d')}</p>
        </li>
        <li>
          <h3>{t('home.valor3_t')}</h3>
          <p>{t('home.valor3_d')}</p>
        </li>
      </ul>
    </div>
  </section>

  <!-- RESEÑAS -->
  {
    resenas.length > 0 && (
      <section class="section resenas-section">
        <div class="container">
          <header class="row-head">
            <div>
              <p class="eyebrow">{t('home.resenas_eyebrow')}</p>
              <h2>{t('home.resenas_title')}</h2>
            </div>
            <a href={L('/resenas')} class="ver-todo">{t('common.ver_todas')}</a>
          </header>
          <Testimonios resenas={resenas} />
        </div>
      </section>
    )
  }

  <!-- PROPIETARIOS -->
  <section class="section">
    <div class="container">
      <div class="prop-band">
        <div>
          <p class="eyebrow on-dark">{t('home.prop_eyebrow')}</p>
          <h2>{t('home.prop_title')}</h2>
          <p class="band-lead">{t('home.prop_lead')}</p>
        </div>
        <div class="band-cta">
          <a href={L('/propietarios')} class="btn btn--primary">{t('home.prop_cta')}</a>
          <WhatsAppButton href={waProp} label={t('home.prop_wa')} />
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding-top: clamp(2.5rem, 6vw, 4.5rem);
    padding-bottom: clamp(2rem, 5vw, 3.5rem);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 0.9fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .hero-text h1 {
    margin-bottom: 1rem;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.8rem;
  }
  .hero-media {
    position: relative;
    display: block;
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 5 / 4;
    box-shadow: var(--shadow-lg);
  }
  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-tag {
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(6px);
    border-radius: 12px;
    padding: 0.7rem 1rem;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow);
  }
  .ht-precio {
    font-family: var(--display);
    font-weight: 600;
    font-size: 1.2rem;
    color: var(--brand);
  }
  .ht-loc {
    font-size: 0.82rem;
    color: var(--muted);
  }
  .cats-section {
    padding-block: 0;
  }
  .cats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .cat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1.3rem 1.4rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    color: var(--ink);
    position: relative;
    transition: border-color 0.15s, transform 0.15s;
  }
  .cat:hover {
    text-decoration: none;
    border-color: var(--brand);
    transform: translateY(-2px);
  }
  .cat-label {
    font-family: var(--display);
    font-size: 1.3rem;
    font-weight: 600;
  }
  .cat-desc {
    font-size: 0.86rem;
    color: var(--muted);
  }
  .cat-arrow {
    position: absolute;
    top: 1.3rem;
    right: 1.3rem;
    color: var(--violet);
    transition: transform 0.15s;
  }
  .cat:hover .cat-arrow {
    transform: translateX(3px);
  }
  .row-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 1.8rem;
    gap: 1rem;
  }
  .row-head h2 {
    margin: 0;
  }
  .ver-todo {
    font-weight: 600;
    white-space: nowrap;
  }
  .porque {
    background: var(--surface);
    border-block: 1px solid var(--line);
  }
  .porque-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .valores {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.5rem;
  }
  .valores li {
    padding-left: 1.3rem;
    border-left: 2px solid var(--violet);
  }
  .valores h3 {
    margin-bottom: 0.3rem;
  }
  .valores p {
    margin: 0;
    color: var(--muted);
  }
  .prop-band {
    display: grid;
    grid-template-columns: 1.4fr 0.8fr;
    gap: 2rem;
    align-items: center;
    background: var(--brand);
    color: #fff;
    border-radius: 22px;
    padding: clamp(2rem, 4vw, 3rem);
  }
  .prop-band h2 {
    color: #fff;
    margin-bottom: 0.6rem;
  }
  .on-dark {
    color: #b9aef2;
  }
  .band-lead {
    color: #cfc8ee;
    margin: 0;
    max-width: 48ch;
  }
  .band-cta {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  @media (max-width: 920px) {
    .hero-grid,
    .porque-grid,
    .prop-band {
      grid-template-columns: 1fr;
    }
    .hero-media {
      order: -1;
    }
    .cats {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 520px) {
    .cats {
      grid-template-columns: 1fr;
    }
  }
</style>
