---
import type { CollectionEntry } from 'astro:content';
import { img } from '../lib/cloudinary';
import {
  formatPrecio,
  formatUbicacion,
  formatSuperficie,
  operacionLabel,
  tipoLabel,
  estadoLabel,
} from '../lib/format';
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/utils';

interface Props {
  bien: CollectionEntry<'biens'>;
}
const { bien } = Astro.props;
const d = bien.data;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
// Si l'annonce a un link externe (ex. site du développeur), la vignette
// envoie directement là-bas, dans un nouvel onglet.
const externo = d.link_externo?.trim();
const href = externo || localizePath(`/propiedad/${bien.id}`, lang);
const target = externo ? '_blank' : undefined;
const rel = externo ? 'noopener' : undefined;

const portada = d.imagenes[0];
const superficie = formatSuperficie(d, lang);
const inactivo = d.estado === 'vendido' || d.estado === 'alquilado';
---

<article class:list={['card', { inactivo }]}>
  <a href={href} target={target} rel={rel} class="media" aria-label={d.titulo}>
    <img
      src={img(portada, { w: 640, h: 440 })}
      alt={d.titulo}
      width="640"
      height="440"
      loading="lazy"
    />
    <div class="tags">
      <span class="badge">{operacionLabel(d.operacion, lang)}</span>
      {d.desarrollo && <span class="badge">{t('badge.pozo')}</span>}
      {
        d.exclusivo && (
          <span class="badge badge--exclusivo">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2l2.9 6.3 6.9.7-5.1 4.6 1.4 6.7L12 17.8 5.9 20.3l1.4-6.7L2.2 9l6.9-.7z" />
            </svg>
            {t('badge.exclusivo')}
          </span>
        )
      }
    </div>
    {
      inactivo && (
        <div class="overlay">
          <span class={`badge badge--${d.estado}`}>{estadoLabel(d.estado, lang)}</span>
        </div>
      )
    }
  </a>

  <div class="body">
    <p class="loc">{tipoLabel(d.tipo, lang)} · {formatUbicacion(d)}</p>
    <h3 class="titulo">
      <a href={href} target={target} rel={rel}>{d.titulo}</a>
    </h3>

    <ul class="specs">
      {d.dormitorios != null && <li>{d.dormitorios} {t('spec.dorm')}</li>}
      {d.banos != null && <li>{d.banos} {t('spec.banos')}</li>}
      {d.cocheras != null && <li>{d.cocheras} {t('spec.coch')}</li>}
      {superficie && <li>{superficie}</li>}
    </ul>

    <div class="foot">
      <span class="precio">{formatPrecio(d, lang)}</span>
      <a href={href} target={target} rel={rel} class="ver">{t('common.ver')}</a>
    </div>
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    height: 100%; /* toutes les cartes d'une rangée font la même hauteur */
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }
  .card.inactivo {
    opacity: 0.82;
  }

  .media {
    position: relative;
    display: block;
    aspect-ratio: 16 / 11;
    background: var(--violet-soft);
  }
  .media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .tags {
    position: absolute;
    top: 0.7rem;
    left: 0.7rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .tags .badge {
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(4px);
    box-shadow: 0 2px 8px -4px rgba(0, 0, 0, 0.3);
  }
  .overlay {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background: rgba(31, 27, 58, 0.32);
  }
  .overlay .badge {
    font-size: 0.95rem;
    padding: 0.5rem 1.1rem;
    background: #fff;
  }

  .body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1; /* occupe tout l'espace pour pousser le pied en bas */
    padding: 1.1rem 1.2rem 1.2rem;
  }
  .loc {
    margin: 0;
    font-size: 0.82rem;
    color: var(--muted);
    letter-spacing: 0.01em;
  }
  .titulo {
    font-size: 1.2rem;
    margin: 0;
    line-height: 1.2;
    /* Max 2 lignes avec "…" : garde toutes les cartes uniformes.
       Le titre complet s'affiche sur la fiche. */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .titulo a {
    color: var(--ink);
  }
  .titulo a:hover {
    color: var(--brand);
    text-decoration: none;
  }
  .specs {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.9rem;
    margin: 0.1rem 0 0;
    padding: 0;
    font-size: 0.86rem;
    color: var(--muted);
  }
  .specs li {
    position: relative;
  }
  .specs li + li::before {
    content: '·';
    position: absolute;
    left: -0.55rem;
    color: var(--line);
  }
  .foot {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-top: auto; /* toujours en bas de la carte */
    padding-top: 0.8rem;
    border-top: 1px solid var(--line);
  }
  .precio {
    font-family: var(--display);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--brand);
  }
  .ver {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--violet);
  }
  .ver:hover {
    text-decoration: none;
    color: var(--brand);
  }
</style>
