---
import { site } from '../lib/site';
import { whatsappLink } from '../lib/whatsapp';
import {
  getLangFromUrl,
  useTranslations,
  localizePath,
  stripLocale,
  LOCALES,
  LANG_LABEL,
} from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const nav = [
  { href: '/comprar', label: t('nav.comprar') },
  { href: '/alquilar', label: t('nav.alquilar') },
  { href: '/desarrollos', label: t('nav.desarrollos') },
  { href: '/terrenos', label: t('nav.terrenos') },
  { href: '/exclusivos', label: t('nav.exclusivos') },
  { href: '/propietarios', label: t('nav.propietarios') },
  { href: '/resenas', label: t('nav.resenas') },
  { href: '/historia', label: t('nav.historia') },
];

// Chemin courant sans préfixe de langue, pour l'état actif et le sélecteur
const basePath = stripLocale(Astro.url.pathname).replace(/\/$/, '') || '/';
const wa = whatsappLink(t('nav.wa_consulta'));
---

<header class="site-header">
  <div class="container bar">
    <a href={localizePath('/', lang)} class="brand" aria-label={`${site.nombre} — inicio`}>
      <img src="/logo-calista.png" alt={site.nombre} class="logo" width="180" height="76" />
    </a>

    <nav class="nav" aria-label="Principal">
      {
        nav.map((item) => (
          <a
            href={localizePath(item.href, lang)}
            class:list={[
              'nav-link',
              { active: basePath === item.href || basePath.startsWith(item.href + '/') },
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="actions">
      <div class="lang-switch" role="group" aria-label="Idioma / langue / language">
        {
          LOCALES.map((l) => (
            <a
              href={localizePath(basePath, l)}
              class:list={['lang', { on: l === lang }]}
              hreflang={l}
              aria-current={l === lang ? 'true' : undefined}
            >
              {LANG_LABEL[l]}
            </a>
          ))
        }
      </div>
      <a href={wa} class="btn btn--primary header-cta" target="_blank" rel="noopener">
        {t('nav.contactar')}
      </a>
      <button class="menu-toggle" aria-label="Menú" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <nav class="mobile-nav" aria-label="Móvil" hidden>
    {nav.map((item) => <a href={localizePath(item.href, lang)}>{item.label}</a>)}
    <a href={localizePath('/contacto', lang)}>{t('nav.contacto')}</a>
    <div class="lang-switch mobile">
      {
        LOCALES.map((l) => (
          <a
            href={localizePath(basePath, l)}
            class:list={['lang', { on: l === lang }]}
            hreflang={l}
          >
            {LANG_LABEL[l]}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--paper) 86%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.2rem;
    height: 72px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    color: var(--ink);
  }
  .brand:hover {
    text-decoration: none;
  }
  .logo {
    height: 40px;
    width: auto;
    display: block;
  }
  .nav {
    display: flex;
    gap: 0.25rem;
    margin-inline: auto;
  }
  .nav-link {
    color: var(--ink);
    font-weight: 500;
    font-size: 0.94rem;
    padding: 0.5rem 0.7rem;
    border-radius: 8px;
    position: relative;
    white-space: nowrap; /* jamais de libellé coupé sur deux lignes */
  }
  .nav-link:hover {
    text-decoration: none;
    background: var(--violet-soft);
  }
  .nav-link.active {
    color: var(--brand);
  }
  .nav-link.active::after {
    content: '';
    position: absolute;
    left: 0.7rem;
    right: 0.7rem;
    bottom: 0.15rem;
    height: 2px;
    background: var(--violet);
    border-radius: 2px;
  }
  .actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  /* Sélecteur de langue */
  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 1px;
    background: var(--violet-soft);
    border-radius: 999px;
    padding: 2px;
  }
  .lang-switch .lang {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: var(--brand-700);
    padding: 0.28rem 0.55rem;
    border-radius: 999px;
    line-height: 1;
  }
  .lang-switch .lang:hover {
    text-decoration: none;
    color: var(--brand);
  }
  .lang-switch .lang.on {
    background: var(--violet);
    color: #fff;
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: 0;
    padding: 8px;
    cursor: pointer;
  }
  .menu-toggle span {
    width: 22px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.2s;
  }
  .mobile-nav {
    flex-direction: column;
    padding: 0.5rem var(--gutter) 1rem;
    border-top: 1px solid var(--line);
  }
  .mobile-nav[hidden] {
    display: none;
  }
  .mobile-nav a:not(.lang) {
    color: var(--ink);
    padding: 0.7rem 0.25rem;
    border-bottom: 1px solid var(--line);
    font-weight: 500;
  }
  .lang-switch.mobile {
    align-self: flex-start;
    margin-top: 0.9rem;
  }

  @media (max-width: 1320px) {
    .nav {
      gap: 0.1rem;
    }
    .nav-link {
      padding: 0.5rem 0.55rem;
      font-size: 0.9rem;
    }
  }
  @media (max-width: 1180px) {
    .nav,
    .header-cta {
      display: none;
    }
    .menu-toggle {
      display: flex;
    }
    .mobile-nav:not([hidden]) {
      display: flex;
    }
  }
</style>

<script>
  const toggle = document.querySelector('.menu-toggle');
  const mobile = document.querySelector('.mobile-nav');
  toggle?.addEventListener('click', () => {
    const open = mobile?.hasAttribute('hidden');
    if (open) mobile?.removeAttribute('hidden');
    else mobile?.setAttribute('hidden', '');
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
