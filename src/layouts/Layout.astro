---
import { site } from '../lib/site';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import {
  getLangFromUrl,
  useTranslations,
  localizePath,
  stripLocale,
  LOCALES,
} from '../i18n/utils';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string; // URL absolue pour l'aperçu de partage
  noindex?: boolean; // pages sans intérêt SEO (ex. page de remerciement)
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const {
  title,
  description = site.lema,
  image,
  noindex = false,
} = Astro.props;

const pageTitle = title ? `${title} · ${site.nombre}` : site.nombre;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = image
  ? new URL(image, Astro.site).toString()
  : new URL('/og-default.png', Astro.site).toString();

// Liens hreflang (es / fr / en) pour la même page
const basePath = stripLocale(Astro.url.pathname);
const alternates = LOCALES.map((l) => ({
  lang: l,
  href: new URL(localizePath(basePath, l), Astro.site).toString(),
}));

// og:locale (langue de la page + langues alternatives)
const OG_LOCALE: Record<string, string> = { es: 'es_ES', fr: 'fr_FR', en: 'en_US' };
const ogLocale = OG_LOCALE[lang];
const ogLocaleAlt = LOCALES.filter((l) => l !== lang).map((l) => OG_LOCALE[l]);

// Données structurées : l'agence immobilière (présent sur toutes les pages).
// Aide Google à comprendre l'entreprise, sa localisation et ses coordonnées.
const siteUrl = new URL('/', Astro.site).toString().replace(/\/$/, '');
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'RealEstateAgent',
  name: site.nombre,
  url: siteUrl,
  image: new URL('/og-default.png', Astro.site).toString(),
  logo: new URL('/logo-calista.png', Astro.site).toString(),
  telephone: '+' + site.whatsapp,
  email: site.email,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Asunción',
    addressCountry: 'PY',
  },
  areaServed: ['Asunción', 'Gran Asunción', 'Paraguay'],
  knowsLanguage: ['es', 'fr', 'en'],
  description: site.lema,
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.lang} href={a.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={alternates[0].href} />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'} />
    <meta name="theme-color" content="#9020c6" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- Aperçu de partage (WhatsApp, réseaux) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.nombre} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale} />
    {ogLocaleAlt.map((l) => <meta property="og:locale:alternate" content={l} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Données structurées : agence immobilière (toutes les pages) -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

    <!-- Polices : Fraunces (display) + Hanken Grotesk (texte) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Hanken+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <!-- Active les animations seulement si le navigateur le permet -->
    <script is:inline>
      if (
        'IntersectionObserver' in window &&
        !matchMedia('(prefers-reduced-motion: reduce)').matches
      ) {
        document.documentElement.classList.add('anim');
      }
    </script>
  </head>
  <body>
    <a href="#contenido" class="skip-link">{t('nav.skip')}</a>
    <Header />
    <main id="contenido">
      <slot />
    </main>
    <Footer />

    <script>
      // Révélation au scroll
      const SEL =
        '.hero-text, .hero-media, .cats > .cat, .row-head, .cab, .grid-biens > *, .porque-intro, .valores > li, .testimonios > .testi, .pasos > li, .incluye > li, .prop-band, .cierre, .gallery, .specs, .cta-card';
      try {
        if (
          document.documentElement.classList.contains('anim') &&
          'IntersectionObserver' in window
        ) {
          const io = new IntersectionObserver(
            (entries) => {
              for (const e of entries) {
                if (e.isIntersecting) {
                  e.target.classList.add('is-visible');
                  io.unobserve(e.target);
                }
              }
            },
            { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
          );
          document.querySelectorAll(SEL).forEach((el) => io.observe(el));
        }
      } catch {
        // En cas de souci, on révèle tout (rien ne reste caché)
        document.documentElement.classList.remove('anim');
      }
    </script>

    <style>
      .skip-link {
        position: absolute;
        left: -999px;
        top: 0;
        background: var(--brand);
        color: #fff;
        padding: 0.6rem 1rem;
        z-index: 100;
        border-radius: 0 0 8px 0;
      }
      .skip-link:focus {
        left: 0;
      }
    </style>
  </body>
</html>
